# Shadow Credit Network — Frontend Environment
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the deployed addresses.
#
# DEPLOYMENT:
#   1. Add your private key to shadow-credit-network/.env:
#        PRIVATE_KEY=your_deployer_private_key_without_0x
#
#   2. Deploy Wave 3 contracts (auto-writes frontend/.env.local):
#        cd shadow-credit-network
#        npx hardhat deploy-wave3 --network base-sepolia
#
#   The deploy task writes frontend/.env.local automatically.
#   You do NOT need to fill this file manually after deployment.
# ─────────────────────────────────────────────────────────────────────────────

# Network
VITE_CHAIN_ID=84532
VITE_RPC_URL=https://sepolia.base.org
VITE_BLOCK_EXPLORER=https://sepolia.basescan.org

# ── Wave 3 Contracts ─────────────────────────────────────────────────────────
# Set these after running: npx hardhat deploy-wave3 --network base-sepolia
# When set, the frontend uses V3 contracts with FHE-gated loan approval,
# lender yield distribution, loan refinancing, and reputation wiring.
VITE_CREDIT_ENGINE_V3_ADDRESS=
VITE_LOAN_POOL_V3_ADDRESS=
VITE_DELEGATION_V2_ADDRESS=
VITE_REPUTATION_REGISTRY_ADDRESS=

# ── Wave 1 Contracts (live on Base Sepolia) ───────────────────────────────────
# These are already deployed. Used as fallback when Wave 3 addresses are empty.
# SimpleCreditEngine: plaintext scoring, no FHE
# PrivateLoanPool:    plaintext loan approval
# CreditDelegation:   yield accumulates but never pays out (V1 bug, fixed in V2)
VITE_SIMPLE_CREDIT_ENGINE_ADDRESS=0x749663A4B343846a7C02d14F7d15c72A2643b02B
VITE_LOAN_POOL_ADDRESS=0x0A2AB73CB8311aFD261Ab92137ff70E9Ca268d69
VITE_DELEGATION_ADDRESS=0xA97c943555E92b7E8472118A3b058e72edcDC694
