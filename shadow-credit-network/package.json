{
	"name": "shadow-credit-network",
	"version": "0.1.0",
	"description": "Privacy-preserving credit and lending protocol powered by FHE",
	"scripts": {
		"test": "REPORT_GAS=true hardhat test",
		"clean": "rimraf ./artifacts ./cache ./coverage ./types ./coverage.json ./deployments/localcofhe",
		"compile": "hardhat compile",
		"--------------": "",
		" --- cofhe ---": "",
		"  --------------": "",
		"// ------------------- ": "",
		"//  --- localcofhe ---": "",
		"//    -------------------": "",
		"// localcofhe:start": "hardhat localcofhe:start --clean true",
		"localcofhe:test": "REPORT_GAS=true hardhat test --network localcofhe",
		"localcofhe:faucet": "hardhat task:cofhe:usefaucet --network localcofhe",
		"// localcofhe:stop": "hardhat localcofhe:stop",
		"// --------------------": "",
		"//  --- SCN Credit Engine ---": "",
		"//   --------------------": "",
		"deploy-credit-engine": "hardhat deploy-credit-engine",
		"eth-sepolia:deploy-credit-engine": "hardhat deploy-credit-engine --network eth-sepolia",
		"arb-sepolia:deploy-credit-engine": "hardhat deploy-credit-engine --network arb-sepolia",
		"base-sepolia:deploy-credit-engine": "hardhat deploy-credit-engine --network base-sepolia",
		"// -------------------": "",
		"//  --- Wave 3 ---": "",
		"//   --------------------": "",
		"base-sepolia:deploy-wave3": "hardhat deploy-wave3 --network base-sepolia",
		"eth-sepolia:deploy-wave3": "hardhat deploy-wave3 --network eth-sepolia",
		"arb-sepolia:deploy-wave3": "hardhat deploy-wave3 --network arb-sepolia",
		"// -------------------": "",
		"//  --- SCN Reputation Registry ---": "",
		"//   --------------------": "",
		"deploy-reputation-registry": "hardhat deploy-reputation-registry",
		"eth-sepolia:deploy-reputation-registry": "hardhat deploy-reputation-registry --network eth-sepolia",
		"arb-sepolia:deploy-reputation-registry": "hardhat deploy-reputation-registry --network arb-sepolia",
		"base-sepolia:deploy-reputation-registry": "hardhat deploy-reputation-registry --network base-sepolia",
		"// -------------------": "",
		"//  --- SCN Private Loan Pool ---": "",
		"//   --------------------": "",
		"deploy-loan-pool": "hardhat deploy-loan-pool",
		"eth-sepolia:deploy-loan-pool": "hardhat deploy-loan-pool --network eth-sepolia",
		"arb-sepolia:deploy-loan-pool": "hardhat deploy-loan-pool --network arb-sepolia",
		"base-sepolia:deploy-loan-pool": "hardhat deploy-loan-pool --network base-sepolia",
		"// -------------------": "",
		"//  --- SCN Credit Delegation ---": "",
		"//   --------------------": "",
		"deploy-credit-delegation": "hardhat deploy-credit-delegation",
		"eth-sepolia:deploy-credit-delegation": "hardhat deploy-credit-delegation --network eth-sepolia",
		"arb-sepolia:deploy-credit-delegation": "hardhat deploy-credit-delegation --network arb-sepolia",
		"base-sepolia:deploy-credit-delegation": "hardhat deploy-credit-delegation --network base-sepolia",
		"// -------------------": "",
		"//  --- SCN ZK Verifier ---": "",
		"//   --------------------": "",
		"deploy-zk-verifier": "hardhat deploy-zk-verifier",
		"eth-sepolia:deploy-zk-verifier": "hardhat deploy-zk-verifier --network eth-sepolia",
		"arb-sepolia:deploy-zk-verifier": "hardhat deploy-zk-verifier --network arb-sepolia",
		"base-sepolia:deploy-zk-verifier": "hardhat deploy-zk-verifier --network base-sepolia",
		"// -------------------": "",
		"//  --- sepolia ---": "",
		"//   --------------------": "",
		"eth-sepolia:deploy-counter": "hardhat deploy-counter --network eth-sepolia",
		"eth-sepolia:increment-counter": "hardhat increment-counter --network eth-sepolia",
		"eth-sepolia:reset-counter": "hardhat reset-counter --network eth-sepolia",
		"// -------------------": "",
		"//  --- arbitrum-sepolia ---": "",
		"//   -------------------": "",
		"arb-sepolia:deploy-counter": "hardhat deploy-counter --network arb-sepolia",
		"arb-sepolia:increment-counter": "hardhat increment-counter --network arb-sepolia",
		"arb-sepolia:reset-counter": "hardhat reset-counter --network arb-sepolia"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fhenixprotocol/cofhe-hardhat-starter.git"
	},
	"author": "Fhenix",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/fhenixprotocol/cofhe-hardhat-starter/issues"
	},
	"homepage": "https://github.com/fhenixprotocol/cofhe-hardhat-starter#readme",
	"devDependencies": {
		"@fhenixprotocol/cofhe-contracts": "^0.0.13",
		"@fhenixprotocol/cofhe-mock-contracts": "^0.3.1",
		"@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
		"@nomicfoundation/hardhat-ethers": "^3.0.0",
		"@nomicfoundation/hardhat-ignition": "^0.15.0",
		"@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
		"@nomicfoundation/hardhat-network-helpers": "^1.0.0",
		"@nomicfoundation/hardhat-toolbox": "^5.0.0",
		"@nomicfoundation/hardhat-verify": "^2.0.0",
		"@openzeppelin/contracts": "^5.0.0",
		"@openzeppelin/contracts-upgradeable": "^5.0.0",
		"@typechain/ethers-v6": "^0.5.0",
		"@typechain/hardhat": "^9.0.0",
		"@types/chai": "^4.2.0",
		"@types/mocha": ">=9.1.0",
		"@types/node": ">=18.0.0",
		"chai": "^4.2.0",
		"cofhe-hardhat-plugin": "^0.3.1",
		"cofhejs": "^0.3.1",
		"dotenv": "^16.4.7",
		"ethers": "^6.4.0",
		"hardhat": "^2.22.19",
		"hardhat-gas-reporter": "^1.0.8",
		"solidity-coverage": "^0.8.0",
		"ts-node": ">=8.0.0",
		"typechain": "^8.3.0",
		"typescript": ">=4.5.0"
	},
	"devDependencies2": {
		"@fhenixprotocol/cofhe-contracts": "0.0.13",
		"@fhenixprotocol/cofhe-mock-contracts": "^0.3.0",
		"cofhe-hardhat-plugin": "^0.3.0",
		"cofhejs": "^0.3.0"
	}
}
